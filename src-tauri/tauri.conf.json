{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dynamic Island Lyrics",
  "version": "0.1.0",
  "identifier": "com.bailaiowo.dynamic-island-lyrics",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "island",
        "title": "Dynamic Island Lyrics",
        "width": 1920,
        "height": 44,
        "x": 660,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "url": "index.html"
      },
      {
        "label": "player",
        "title": "Player",
        "width": 360,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": false,
        "url": "player.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
